# ==========================================================================
# FlowAssist Backend — variaveis de ambiente
# Copie para .env e ajuste os valores. NUNCA versione o .env real.
# ==========================================================================

# ---- Banco de dados (PostgreSQL) ----
# Use o docker-compose.yml deste diretorio para subir um Postgres com pgvector.
DATABASE_URL="postgresql://flowassist:flowassist@localhost:5434/flowassist?schema=public"

# ---- Servidor ----
PORT=3000
NODE_ENV=development
# Origem do frontend (Vite). Usado pelo CORS. Aceita lista separada por virgula.
CORS_ORIGIN="http://localhost:5173"

# ---- Autenticacao (JWT) ----
JWT_SECRET="troque_por_uma_chave_aleatoria_com_no_minimo_32_caracteres"
JWT_EXPIRES_IN="7d"

# ---- Feature flags de "mock mode" ----
# Quando true, o backend roda 100% standalone (sem N8N/LLM/Evolution reais).
# Quando false, os clientes correspondentes passam a chamar os servicos reais.
MOCK_AI=true
MOCK_RAG=true
MOCK_WHATSAPP=true

# ---- N8N (usado quando as flags acima sao false) ----
N8N_URL="http://localhost:5678"
N8N_WEBHOOK_SECRET="troque_por_um_segredo_para_o_n8n"

# ---- LLM (usado quando MOCK_AI=false; o N8N normalmente cuida disso) ----
OPENAI_API_KEY=""

# ---- Evolution API / WhatsApp (usado quando MOCK_WHATSAPP=false) ----
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY=""

# ---- Webhooks (Evolution/N8N -> Backend) ----
# Header esperado: x-webhook-secret
WEBHOOK_SECRET="troque_por_um_segredo_para_webhooks"

# ---- Storage de arquivos da Base de Conhecimento ----
# 'local' grava em ./uploads. No futuro: 's3' ou 'supabase'.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="uploads"
# Tamanho maximo por arquivo (bytes). Padrao: 20MB.
MAX_UPLOAD_BYTES=20971520
