    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT a.id AS agent_id FROM agents a\nJOIN whatsapp_connections w ON w.agent_id = a.id\nWHERE w.instance_name = $1 OR a.id::text LIKE $2 || '%'\nLIMIT 1;",
        "options": {
          "queryReplacement": "={{ $('Parse mensagem').item.json.instanceName }},{{ $('Parse mensagem').item.json.agentIdSuffix }}"
        }
      },
      "id": "67b25b5b-00d4-46b4-bc81-2218be971a13",
