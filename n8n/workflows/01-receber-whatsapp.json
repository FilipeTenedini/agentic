    {
      "parameters": {
        "jsCode": "const p = $input.first().json;\nif (p.data?.key?.fromMe === true) return [{ json: { skip: true } }];\n\nconst instanceName = p.instance || p.instanceName;\nconst remoteJid = p.data?.key?.remoteJid || '';\nconst contactName = p.data?.pushName || 'Contato';\nconst msg = p.data?.message || {};\nconst message = msg.conversation || msg.extendedTextMessage?.text || '';\n\nif (!message?.trim() || !instanceName) return [{ json: { skip: true } }];\n\nconst suffix = String(instanceName).replace('flowassist-', '');\nreturn [{\n  json: {\n    skip: false,\n    instanceName,\n    agentIdSuffix: suffix,\n    contactPhone: remoteJid,\n    contactName,\n    externalId: remoteJid,\n    message: message.trim(),\n  },\n}];",
        "mode": "runOnceForAllItems"
      },
      "id": "76900ba8-ea56-4fc4-8e0a-6a97dcc1e030",
      "name": "Parse mensagem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        300
      ]
    },
    {
