        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const prep = $('Preparar LLM').item.json;\nlet reply = 'Desculpe, nao consegui processar sua mensagem agora. Tente novamente.';\ntry {\n  const choices = $input.first().json.choices;\n  if (choices?.[0]?.message?.content) {\n    reply = choices[0].message.content;\n  }\n} catch {}\nreturn [{ json: { reply } }];",
        "mode": "runOnceForAllItems"
      },
