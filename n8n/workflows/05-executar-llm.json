    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst viaWebhook = item.source === 'webhook';\nconst body = viaWebhook ? item : item;\nconst p = body.personality || {};\nconst messages = [{ role: 'system', content: body.systemPrompt || 'Voce e um assistente util.' }];\n\nfor (const msg of (body.history || [])) {\n  messages.push({ role: msg.role, content: msg.content });\n}\nmessages.push({ role: 'user', content: body.userMessage });\n\nconst temperature = (p.temperature ?? 50) / 100;\nconst max_tokens = { curta: 256, media: 512, longa: 1024 }[p.responseLength] || 512;\n\nreturn [{ json: { viaWebhook, messages, temperature, max_tokens } }];",
        "mode": "runOnceForAllItems"
      },
      "id": "ef5610a0-18ea-4249-8cb3-fc3a93726ed5",
      "name": "Preparar LLM",
      "type": "n8n-nodes-base.code",
