        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENAI_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"gpt-4o-mini\", messages: $(\"Preparar LLM\").item.json.messages, temperature: $(\"Preparar LLM\").item.json.temperature, max_tokens: $(\"Preparar LLM\").item.json.max_tokens }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
