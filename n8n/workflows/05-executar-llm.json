    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst headers = item.headers || {};\nconst secret = headers['x-webhook-secret'] || headers['X-Webhook-Secret'];\nconst expected = $env.N8N_WEBHOOK_SECRET || 'dev-webhook-secret';\nif (secret !== expected) return [{ json: { unauthorized: true } }];\nconst body = item.body ?? item;\nreturn [{ json: { unauthorized: false, source: 'webhook', ...body } }];",
        "mode": "runOnceForAllItems"
      },
