            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ chunks: $json.chunks }) }}"
      },
      "id": "9b0961e5-c6b0-4540-8d53-ec8a94fbaca2",
      "name": "Salvar chunks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
